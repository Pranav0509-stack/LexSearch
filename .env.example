# ═══════════════════════════════════════════════════
#  LexSearch — Environment Variables
# ═══════════════════════════════════════════════════

# Path to the pre-built BM25 pickle. If missing, server.py builds one on
# first /retrieve (takes ~5 min and pulls ~2M docs from S3). In production
# you should `python ingest/rebuild_bm25.py` nightly.
LEXSEARCH_BM25_PATH=./bm25.pkl

# Feature toggle. Set "false" to disable /retrieve and /judgment endpoints
# (the /search path keeps working either way).
LEXSEARCH_BM25_ENABLED=true

# Cap document count for dev / smoke tests. Blank/0 = full index.
LEXSEARCH_BM25_MAX_DOCS=0

# If "true" (default), the index loads in a background thread at startup so
# the API is up immediately. Set "false" for synchronous boot-time load.
LEXSEARCH_BM25_LAZY=true

# Token for POST /admin/reload (hot-reload after rebuild_bm25.py writes a
# fresh pickle). If unset, the endpoint returns 403.
LEXSEARCH_ADMIN_TOKEN=

# ── Ingestion ────────────────────────────────────────
# HC_DAILY_RATE_LIMIT_S — gap (seconds) between requests per HC adapter.
HC_DAILY_RATE_LIMIT_S=2.0
# LEXSEARCH_S3_WRITE=false disables S3 writes (uses ./out_* dirs instead).
LEXSEARCH_S3_WRITE=true

# For rebuild_bm25.py → server.py hot-reload:
LEXSEARCH_ADMIN_URL=http://localhost:8080

# ── Phase 2: Brief assistant + access-request flow ──
# SQLite path (access requests, codes, chat threads + messages)
LEXSEARCH_DB_PATH=./lexsearch.db

# HMAC key for signing session cookies. If unset, a random 32-byte key is
# generated at startup and persisted to ./.secret (gitignored). Set this
# explicitly in production so cookies survive container rebuilds.
LEXSEARCH_SECRET_KEY=

# ── LLM Router (Sanhita Brief) ───────────────────────────────────────
# Sanhita uses a 3-provider chain with circuit-breaker fallback:
#   1. Groq (primary)         — free tier, Llama 3.3 70B Versatile, sub-second TTFT
#   2. Cloudflare Workers AI  — free, Llama 3.1 8B at the Mumbai edge (helper / fallback)
#   3. Gemini (tertiary)      — paid fallback only
#
# If none is set, /api/brief/chat returns a clean refusal with the closest
# 3 cases — no fabricated prose.

# Groq — get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Cloudflare Workers AI — https://dash.cloudflare.com → AI → Workers AI
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_MODEL=@cf/meta/llama-3.1-8b-instruct

# Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Per-call timeout for any LLM provider (seconds).
LLM_TIMEOUT_S=18
