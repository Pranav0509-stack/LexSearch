# ═══════════════════════════════════════════════════
#  Sanhita — Environment Variables
# ═══════════════════════════════════════════════════

# ── Database ────────────────────────────────────────
# Path to the 81GB india_courts.db (FTS5-indexed SQLite)
INDIA_COURTS_DB=/data/india_courts.db

# SQLite path for auth/sessions/chat threads
LEXSEARCH_DB_PATH=./lexsearch.db

# ── BM25 / Retrieval ───────────────────────────────
LEXSEARCH_BM25_ENABLED=true
LEXSEARCH_BM25_LAZY=true

# ── Auth ────────────────────────────────────────────
# HMAC key for session cookies. Set explicitly in production.
LEXSEARCH_SECRET_KEY=
# Demo access code
DEMO_CODE=SNHT-DEMO-2026

# ── LLM Providers ──────────────────────────────────
# Gemini (primary) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Per-call timeout (seconds)
LLM_TIMEOUT_S=45

# ── Deployment ──────────────────────────────────────
# Port (Railway/Render set this automatically)
PORT=8080

# Frontend origin for CORS (set in production)
# FRONTEND_ORIGIN=https://sanhita.law
