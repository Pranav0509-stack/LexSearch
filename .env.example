# ═══════════════════════════════════════════════════
#  NyayaSathi v12 — Environment Variables
# ═══════════════════════════════════════════════════

# Sarvam AI — STT + TTS (required)
# Get free key: https://dashboard.sarvam.ai
SARVAM_API_KEY=YOUR_SARVAM_KEY_HERE

# Google Gemini — AI Brain (required)
# Get free key: https://aistudio.google.com
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# Exotel — Phone integration (optional, for phone calls)
# Get account: https://exotel.com
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_CALLER_ID=

# Public URL — required for Exotel webhooks
# Run: cloudflared tunnel --url http://localhost:3000
# Or:  ngrok http 3000
PUBLIC_URL=

# Server port (default 3000)
PORT=3000
