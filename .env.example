# Copy to .env and fill in. Never commit .env.

ENV=dev
LOG_LEVEL=INFO

# Postgres
DATABASE_URL=postgresql+asyncpg://nyayasathi:nyayasathi@localhost:5432/nyayasathi
DATABASE_URL_SYNC=postgresql+psycopg2://nyayasathi:nyayasathi@localhost:5432/nyayasathi

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Plivo (Indian PSTN)
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_PHONE_NUMBER=
PLIVO_WEBHOOK_SECRET=

# Sarvam AI (Saaras ASR, Bulbul TTS, Sarvam-M LLM)
SARVAM_API_KEY=
SARVAM_ASR_MODEL=saaras:v2
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_LLM_MODEL=sarvam-m

# AWS
AWS_REGION=ap-south-1
S3_BUCKET_STATIC=nyayasathi-static
S3_BUCKET_PROD=nyayasathi-prod
SES_SENDER=no-reply@nyayasathi.in
KMS_KEY_ID=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Observability
SENTRY_DSN=

# Feature flags
ENABLE_ASR_FALLBACK=false
ENABLE_LLM_FALLBACK=false
ENABLE_TTS_FALLBACK=false
